<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.myproject01.members.mapper.MembersMapper">
    <insert id="register" parameterType="MembersVO">
        insert into members(m_id, m_pw, m_name, m_addr, m_email, m_phone)
        values(#{m_id}, #{m_pw}, #{m_name}, #{m_addr}, #{m_email}, #{m_phone})
    </insert>
    <!-- [ORACLE] register: AUTO_INCREMENT 대신 SEQUENCE 사용
        <selectKey keyProperty="m_idx" resultType="string" order="BEFORE">
            SELECT members_seq.NEXTVAL FROM dual
        </selectKey>
        insert into members(m_idx, m_id, m_pw, m_name, m_addr, m_email, m_phone)
        values(#{m_idx}, #{m_id}, #{m_pw}, #{m_name}, #{m_addr}, #{m_email}, #{m_phone})
    -->

    <select id="findById" parameterType="userId" resultType="MembersVO">
        select * from members where m_active = 0 and m_id=#{m_id}
    </select>

    <update id="memberUpdate" parameterType="String">
        update into members where m_id = #{m_id}
    </update>

    <insert id="saveRefreshToken" parameterType="RefreshTokenVO">
        insert into refresh_tokens (rt_user_id, rt_token)
        values(#{rt_user_id}, #{rt_token})
    </insert>

    <select id="findRefreshToken" parameterType="String" resultType="RefreshTokenVO">
        select * from refresh_tokens where rt_token=#{rt_token}
    </select>

    <update id="deleteMember" parameterType="String">
        update into
        members _____=#{_____}, _____=#{_____}, _____=#{_____},
            _____=#{_____}, _____=#{_____}
        where m_id=#{m_id} and m_active=0
    </update>

    <delete id="deleteRefreshToken" parameterType="String">
        delete from refresh_tokens _____=_____, _____=_____() _____ _____=#{_____}
    </delete>
    <!-- [ORACLE] delete: now() → sysdate -->
</mapper>
