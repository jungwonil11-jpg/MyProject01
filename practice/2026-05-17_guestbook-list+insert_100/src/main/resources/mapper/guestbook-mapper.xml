<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.myproject01.guestbook.mapper.GuestBookMapper">
   <select id="getGuestBookList" resultType="GuestBookVO">
       select * from guestbook where g_active = 0
   </select>
    <insert id="getGuestBookInsert" parameterType="gvo">
        insert into guestbook(g_content, g_writer, g_subject, g_email, g_pwd, g_regdate)
        guestbook(#{g_content}, #{g_writer}, #{g_subject}, #{g_email}, #{g_pwd}, now())
    </insert>
</mapper>
