<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    방명록 MyBatis 매퍼 XML.

    namespace: GuestBookMapper 인터페이스의 전체 경로와 반드시 일치해야 한다.
               MyBatis는 이 값으로 인터페이스 메서드와 SQL 구문을 연결(바인딩)한다.

    각 태그의 id 속성은 GuestBookMapper 인터페이스의 메서드명과 동일해야 한다.
    resultType/parameterType에서 "GuestBookVO"가 단순 클래스명으로 동작하는 이유는
    application.yaml의 type-aliases-package 설정 덕분이다.
-->
<mapper namespace="com.study.myproject01.guestbook.mapper.GuestBookMapper">

    <!--
        [목록 조회] guestBookList()
        g_active = 0 인 게시글만 조회한다 (소프트 딜리트: 1이면 삭제된 글).
        resultType="GuestBookVO" — 조회 결과 각 행을 GuestBookVO 객체로 자동 매핑한다.
        컬럼명과 VO 필드명이 일치하므로 별도의 resultMap 없이 자동 매핑이 가능하다.
    -->
    <select id="guestBookList" resultType="GuestBookVO">
        SELECT * FROM guestbook WHERE g_active = 0
    </select>

    <!--
        [상세 조회] guestBookDetail(String g_idx)
        parameterType="String" — 단일 String 파라미터를 받는다.
        #{g_idx} — MyBatis의 PreparedStatement 바인딩. SQL 인젝션을 방지한다.
        g_active = 0 조건을 추가하여 삭제된 글은 조회되지 않도록 한다.
    -->
    <select id="guestBookDetail" parameterType="String" resultType="GuestBookVO">
        SELECT * FROM guestbook WHERE g_idx = #{g_idx} AND g_active = 0
    </select>

    <!--
        [등록] guestBookWInsert(GuestBookVO gvo)
        parameterType="GuestBookVO" — VO 객체를 파라미터로 받는다.
        #{필드명} 으로 VO의 getter를 호출하여 값을 바인딩한다.
        g_regdate는 파라미터로 받지 않고 SQL의 now()로 현재 시각을 자동 입력한다.
        g_active의 기본값은 DB 스키마에서 DEFAULT 0으로 설정되어 있어 생략 가능하다.
        g_idx는 AUTO_INCREMENT이므로 INSERT 컬럼 목록에서 제외한다.
    -->
    <insert id="guestBookWInsert" parameterType="GuestBookVO">
        INSERT INTO guestbook (g_writer, g_subject, g_content, g_email, g_pwd, g_regdate)
        VALUES (#{g_writer}, #{g_subject}, #{g_content}, #{g_email}, #{g_pwd}, now())
    </insert>

    <!--
        [논리 삭제] guestBookDelete(String g_idx)
        실제 행(row)을 DELETE하지 않고 g_active 플래그를 1로 변경하는 소프트 딜리트 방식.
        데이터를 보존하면서 조회에서만 제외할 수 있어 복구나 로그 추적이 용이하다.
        MyBatis에서는 <delete> 태그를 사용하지만 내부 SQL은 UPDATE이다.
        (태그 종류는 의미론적 구분일 뿐, 어떤 SQL이든 실행 가능하다.)
    -->
    <delete id="guestBookDelete" parameterType="String">
        UPDATE guestbook SET g_active = 1 WHERE g_idx = #{g_idx}
    </delete>

    <!--
        [수정] guestBookUpdate(GuestBookVO gvo)
        g_idx를 기준으로 작성자(g_writer), 제목(g_subject), 이메일(g_email), 본문(g_content)을 수정한다.
        g_regdate, g_pwd, g_active는 수정 대상에서 제외한다.
        WHERE 절에 g_idx를 반드시 포함해야 특정 행만 업데이트된다.
    -->
    <update id="guestBookUpdate" parameterType="GuestBookVO">
        UPDATE guestbook
        SET g_writer  = #{g_writer},
            g_subject = #{g_subject},
            g_email   = #{g_email},
            g_content = #{g_content}
        WHERE g_idx = #{g_idx}
    </update>

</mapper>
